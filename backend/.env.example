# ================================
# FAMILY CONNECT BACKEND CONFIG
# ================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_USER=your_atlas_db_user
MONGO_PASSWORD=your_atlas_db_password
MONGO_HOST=cluster0.p56yoyl.mongodb.net
MONGO_DB=family_connect
MONGO_URI=mongodb+srv://your_atlas_db_user:your_atlas_db_password@cluster0.p56yoyl.mongodb.net/family_connect?retryWrites=true&w=majority

# Local MongoDB (no username/password) — use this when Atlas is unreachable:
# MONGO_URI=mongodb://127.0.0.1:27017/family_connect

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRE=90d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# App Settings
CLIENT_URL=http://localhost:3000
MAX_FILE_SIZE_MB=10
INVITE_CODE_EXPIRY_HOURS=48

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
