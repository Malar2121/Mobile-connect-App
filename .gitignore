# ============================================================
# Family Connect — Monorepo Root .gitignore
# ============================================================

# Dependencies
node_modules/

# Environment & secrets (keep .env.example)
.env
.env.local
.env.*.local

# Expo / React Native tooling
.expo/
.expo-shared/
.expo-audit/
.expo-bundle-test/
web-build/
expo-env.d.ts

# Android / iOS build outputs (keep android/ source)
family-connect-mobile/android/app/build/
family-connect-mobile/android/build/
family-connect-mobile/android/.gradle/
family-connect-mobile/android/.cxx/
family-connect-mobile/android/local.properties
family-connect-mobile/ios/build/

# Build artifacts
dist/
coverage/
tmp/
*.apk
*.aab

# Logs
logs/
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Signing keys
*.keystore
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# OS / editor
.DS_Store
Thumbs.db
*.orig.*
.kotlin/
.metro-health-check*
*.tsbuildinfo
*.iml
*.hprof

# IDE (optional local)
.idea/
